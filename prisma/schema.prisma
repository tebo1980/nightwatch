generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id               String         @id @default(cuid())
  businessName     String
  agentName        String
  agentPersonality String
  serviceArea      String
  jobTypes         String
  pricingRanges    String
  emergencyAvail   Boolean        @default(false)
  businessHours    String
  phoneNumber      String
  email            String
  website          String?
  ghlWebhookUrl    String?
  ghlApiKey        String?
  widgetColor      String         @default("#C17B2A")
  greeting         String         @default("Hi! How can I help you today?")
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  conversations    Conversation[]
  leads            Lead[]
}

model Conversation {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
  sessionId    String    @unique
  messages     String
  status       String    @default("active")
  leadCaptured Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lead         Lead?
}

model Lead {
  id                  String       @id @default(cuid())
  clientId            String
  client              Client       @relation(fields: [clientId], references: [id])
  conversationId      String       @unique
  conversation        Conversation @relation(fields: [conversationId], references: [id])
  firstName           String
  lastName            String?
  email               String?
  phone               String
  address             String?
  city                String?
  jobType             String
  jobDescription      String
  urgency             String
  quoteRangeLow       Int?
  quoteRangeHigh      Int?
  bestTimeToCall      String?
  conversationSummary String
  sentToGHL           Boolean      @default(false)
  createdAt           DateTime     @default(now())
}
