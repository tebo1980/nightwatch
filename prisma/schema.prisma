generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id               String         @id @default(cuid())
  businessName     String
  agentName        String
  agentPersonality String
  serviceArea      String
  jobTypes         String
  pricingRanges    String
  emergencyAvail   Boolean        @default(false)
  businessHours    String
  phoneNumber      String
  email            String
  website          String?
  ghlWebhookUrl    String?
  ghlApiKey        String?
  widgetColor      String         @default("#C17B2A")
  greeting         String         @default("Hi! How can I help you today?")
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  conversations    Conversation[]
  leads            Lead[]
}

model Conversation {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
  sessionId    String    @unique
  messages     String
  status       String    @default("active")
  leadCaptured Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lead         Lead?
}

model Lead {
  id                  String       @id @default(cuid())
  clientId            String
  client              Client       @relation(fields: [clientId], references: [id])
  conversationId      String       @unique
  conversation        Conversation @relation(fields: [conversationId], references: [id])
  firstName           String
  lastName            String?
  email               String?
  phone               String
  address             String?
  city                String?
  jobType             String
  jobDescription      String
  urgency             String
  quoteRangeLow       Int?
  quoteRangeHigh      Int?
  bestTimeToCall      String?
  conversationSummary String
  sentToGHL           Boolean      @default(false)
  createdAt           DateTime     @default(now())
}

// ─── BaraTrust AI Staff: Shared Client Table ───────────────────────────

model AgentClient {
  id                    String   @id @default(cuid())

  // Business Identity
  businessName          String
  industry              String
  ownerName             String
  ownerFirstName        String
  ownerEmail            String
  contactPhone          String?
  website               String?
  city                  String
  state                 String
  zipCode               String?
  businessAddress       String?

  // Brand Voice
  tonePreference        String   @default("friendly")
  tagline               String?
  servicesOffered       String
  typicalJobTypes       String?
  avgTicketSize         String?
  idealCustomer         String?

  // Agent Toggles
  novaEnabled           Boolean  @default(false)
  rexEnabled            Boolean  @default(false)
  irisEnabled           Boolean  @default(false)
  maxEnabled            Boolean  @default(false)
  dellaEnabled          Boolean  @default(false)
  flynnEnabled          Boolean  @default(false)
  coleEnabled           Boolean  @default(false)
  riverEnabled          Boolean  @default(false)
  sageEnabled           Boolean  @default(false)
  atlasEnabled          Boolean  @default(false)

  // Rex-specific config
  googleReviewLink      String?
  googlePlaceId         String?
  yelpBusinessId        String?
  rexLastScrapeAt       DateTime?

  // Iris-specific config
  irisFollowUpDay1      Int      @default(1)
  irisFollowUpDay2      Int      @default(3)
  irisFollowUpDay3      Int      @default(7)

  // Max-specific config
  maxReviewDelayDays    Int      @default(2)
  maxPaymentReminderDays String  @default("7,14,30")

  // River-specific config
  riverBusinessHours    String?
  riverAppointmentTypes String?

  // Subscription info
  tier                  String   @default("complete")
  active                Boolean  @default(true)
  startedAt             DateTime @default(now())
  notes                 String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  reviews               Review[]
  weeklyRepReports      WeeklyRepReport[]
  irisLeads             IrisLead[]
  maxJobs               MaxJob[]
  maxInvoices           MaxInvoice[]
  dellaDrafts           DellaDraft[]
  flynnVehicles         FlynnVehicle[]
  coleInventoryItems    ColeInventoryItem[]
  riverAppointments     RiverAppointment[]
  sagePosts             SagePost[]
}

// ─── Stub models for agent relations (will be expanded per agent) ──────

model Review {
  id              String      @id @default(cuid())
  clientId        String
  client          AgentClient @relation(fields: [clientId], references: [id])
  platform        String      // "google" | "yelp" | "facebook" | "manual"
  externalId      String?     // platform's own review ID (for dedup)
  reviewerName    String
  rating          Int         // 1-5
  reviewText      String
  reviewDate      DateTime
  draftResponse   String?
  finalResponse   String?
  status          String      @default("pending") // pending | drafted | approved | posted
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([clientId, platform, externalId])
}

model WeeklyRepReport {
  id              String      @id @default(cuid())
  clientId        String
  client          AgentClient @relation(fields: [clientId], references: [id])
  weekStart       DateTime
  weekEnd         DateTime
  totalReviews    Int
  avgRating       Float
  fiveStarCount   Int
  oneStarCount    Int
  summaryText     String
  sentAt          DateTime?
  createdAt       DateTime    @default(now())
}

model IrisLead {
  id                String       @id @default(cuid())
  clientId          String
  client            AgentClient  @relation(fields: [clientId], references: [id])
  novaLeadId        String?      // Links back to Nova's Lead.id if it came through Nova
  leadName          String
  leadEmail         String?
  leadPhone         String?
  source            String       @default("nova")
  serviceNeeded     String?
  initialMessage    String?
  status            String       @default("new") // new | following-up | converted | exhausted | dead
  followUpCount     Int          @default(0)
  lastFollowUpAt    DateTime?
  nextFollowUpAt    DateTime?
  convertedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  followUps         IrisFollowUp[]
}

model IrisFollowUp {
  id            String    @id @default(cuid())
  leadId        String
  lead          IrisLead  @relation(fields: [leadId], references: [id])
  followUpNum   Int
  channel       String    // "email" | "sms-note"
  subject       String?
  message       String
  sentAt        DateTime?
  status        String    @default("pending") // pending | sent | failed
  createdAt     DateTime  @default(now())
}

model MaxJob {
  id                String      @id @default(cuid())
  clientId          String
  client            AgentClient @relation(fields: [clientId], references: [id])
  customerName      String
  customerEmail     String?
  customerPhone     String?
  serviceProvided   String
  jobValue          Float?
  completedAt       DateTime
  notes             String?
  reviewRequested   Boolean     @default(false)
  reviewRequestedAt DateTime?
  reviewReceived    Boolean     @default(false)
  createdAt         DateTime    @default(now())
}

model MaxInvoice {
  id              String       @id @default(cuid())
  clientId        String
  client          AgentClient  @relation(fields: [clientId], references: [id])
  customerName    String
  customerEmail   String?
  customerPhone   String?
  invoiceNumber   String?
  amount          Float
  description     String?
  dueDate         DateTime
  paidAt          DateTime?
  status          String       @default("unpaid") // unpaid | paid | written-off
  remindersCount  Int          @default(0)
  lastReminderAt  DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  reminders       MaxReminder[]
}

model MaxReminder {
  id            String     @id @default(cuid())
  invoiceId     String
  invoice       MaxInvoice @relation(fields: [invoiceId], references: [id])
  reminderNum   Int
  message       String
  sentAt        DateTime?
  status        String     @default("pending")
  createdAt     DateTime   @default(now())
}

model DellaDraft {
  id              String      @id @default(cuid())
  clientId        String
  client          AgentClient @relation(fields: [clientId], references: [id])
  emailType       String
  recipientName   String
  recipientEmail  String?
  subject         String
  body            String
  requestNotes    String?
  status          String      @default("draft") // draft | sent | discarded
  sentAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ─── Flynn: Fleet & Vehicle Tracking ──────────────────────────────

model FlynnVehicle {
  id              String      @id @default(cuid())
  clientId        String
  client          AgentClient @relation(fields: [clientId], references: [id])
  vehicleName     String
  make            String
  model           String
  year            Int
  licensePlate    String?
  currentMileage  Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  fuelLogs        FuelLog[]
  maintenanceLogs MaintenanceLog[]
}

model FuelLog {
  id            String        @id @default(cuid())
  vehicleId     String
  vehicle       FlynnVehicle  @relation(fields: [vehicleId], references: [id])
  date          DateTime
  gallons       Float
  costPerGallon Float
  totalCost     Float
  mileageAtFill Int
  createdAt     DateTime      @default(now())
}

model MaintenanceLog {
  id               String        @id @default(cuid())
  vehicleId        String
  vehicle          FlynnVehicle  @relation(fields: [vehicleId], references: [id])
  date             DateTime
  type             String
  cost             Float
  mileageAtService Int
  notes            String?
  nextDueMileage   Int?
  createdAt        DateTime      @default(now())
}

// ─── Cole: Cost of Goods & Inventory ──────────────────────────────

model ColeInventoryItem {
  id            String      @id @default(cuid())
  clientId      String
  client        AgentClient @relation(fields: [clientId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ExpenseEntry {
  id           String   @id @default(cuid())
  clientId     String
  date         DateTime
  vendor       String
  category     String
  description  String
  amount       Float
  jobReference String?
  receiptUrl   String?
  createdAt    DateTime @default(now())
}

model JobRevenue {
  id        String   @id @default(cuid())
  clientId  String
  date      DateTime
  jobName   String
  jobType   String
  revenue   Float
  notes     String?
  createdAt DateTime @default(now())
}

// ─── River: Appointments & Reminders ──────────────────────────────

model RiverAppointment {
  id                    String                @id @default(cuid())
  clientId              String
  client                AgentClient           @relation(fields: [clientId], references: [id])
  customerName          String
  customerPhone         String
  customerEmail         String?
  serviceType           String
  scheduledAt           DateTime
  durationMinutes       Int                   @default(60)
  providerName          String?
  notes                 String?
  status                String                @default("scheduled")
  recoveryMessageSentAt DateTime?
  reminders             AppointmentReminder[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

model AppointmentReminder {
  id            String           @id @default(cuid())
  appointmentId String
  appointment   RiverAppointment @relation(fields: [appointmentId], references: [id])
  type          String
  scheduledFor  DateTime
  sentAt        DateTime?
  status        String           @default("pending")
  message       String
  createdAt     DateTime         @default(now())
}

// ─── Scraper Engine ─────────────────────────────────────────────

model ScraperTarget {
  id             String        @id @default(cuid())
  name           String
  category       String
  url            String
  priceSelector  String
  targetTable    String
  targetField    String
  targetRecordId String
  frequency      String        @default("weekly")
  isActive       Boolean       @default(true)
  lastScraped    DateTime?
  lastResult     String?
  lastStatus     String?
  sourceStore    String?       // HomeDepot, Lowes, Menards, SupplyHouse, SherwinWilliams, Amazon, Walmart, Target, Other
  isPrimary      Boolean       @default(false)
  isReference    Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  logs           ScraperLog[]
}

model ScraperLog {
  id                   String        @id @default(cuid())
  targetId             String
  target               ScraperTarget @relation(fields: [targetId], references: [id])
  result               String?
  status               String
  errorMsg             String?
  isReferenceFailure   Boolean       @default(false)
  scrapedAt            DateTime      @default(now())
}

// ─── Atlas: Material Pricing ─────────────────────────────────────

model MaterialPrice {
  id                    String    @id @default(cuid())
  name                  String
  trade                 String    // Plumber, HVAC, Electrician, GC, etc.
  unit                  String    // each, linear foot, gallon, etc.
  currentPrice          Float?
  previousPrice         Float?
  percentChange         Float?
  lowPrice              Float?
  highPrice             Float?
  sourceUrl             String?
  hdPrice               Float?
  lowesPrice            Float?
  menardsPrice          Float?
  supplyHousePrice      Float?
  sherwinWilliamsPrice  Float?
  amazonPrice           Float?
  walmartPrice          Float?
  targetPrice           Float?
  primarySource         String?
  category              String?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  alerts                PriceAlert[]
}

model PriceAlert {
  id            String        @id @default(cuid())
  materialId    String
  material      MaterialPrice @relation(fields: [materialId], references: [id])
  sourceStore   String?
  previousPrice Float
  newPrice      Float
  percentChange Float
  acknowledged  Boolean       @default(false)
  createdAt     DateTime      @default(now())
}

// ─── Sage: Social Media Posts ─────────────────────────────────────

model SagePost {
  id            String      @id @default(cuid())
  clientId      String
  client        AgentClient @relation(fields: [clientId], references: [id])
  platform      String
  content       String
  scheduledFor  DateTime?
  postedAt      DateTime?
  status        String      @default("draft")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// ─── Bolt: On-Site Estimate Builder ─────────────────────────────────

model ClientBoltConfig {
  id               String     @id @default(cuid())
  clientId         String     @unique
  clientSlug       String     @unique
  businessName     String
  businessPhone    String
  businessEmail    String
  businessAddress  String?
  logoUrl          String?
  licenseNumber    String?
  insuranceInfo    String?
  trade            String
  laborRatePerHour Float      @default(75)
  minimumJobSize   Float      @default(150)
  taxRate          Float      @default(0)
  paymentTerms     String     @default("50% deposit required to schedule. Balance due upon completion.")
  warrantyTerms    String     @default("All work warranted for 1 year from completion date.")
  validityDays     Int        @default(14)
  escalationClause Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  estimates        Estimate[]
}

model Estimate {
  id              String           @id @default(cuid())
  clientId        String
  boltConfig      ClientBoltConfig @relation(fields: [clientId], references: [clientId])
  estimateNumber  String           @unique
  customerName    String
  customerPhone   String
  customerEmail   String?
  customerAddress String
  jobType         String
  jobDescription  String
  lineItems       Json
  laborHours      Float
  laborRate       Float
  laborTotal      Float
  materialsTotal  Float
  subtotal        Float
  taxAmount       Float
  totalAmount     Float
  depositRequired Float
  validUntil      DateTime
  status          String           @default("draft")
  sentAt          DateTime?
  approvedAt      DateTime?
  notes           String?
  internalNotes   String?
  pdfUrl          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}
